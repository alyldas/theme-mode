{
  "name": "@alyldas/theme-mode",
  "version": "1.0.1",
  "description": "Nuxt-first color mode controller with Vue and core entry points.",
  "type": "module",
  "license": "MIT",
  "author": "alyldas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alyldas/theme-mode.git"
  },
  "bugs": {
    "url": "https://github.com/alyldas/theme-mode/issues"
  },
  "homepage": "https://alyldas.github.io/theme-mode/",
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "sideEffects": [
    "./dist/style.css"
  ],
  "files": [
    "dist",
    "docs/demo.html",
    "docs/screenshots"
  ],
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js",
      "require": "./dist/vue/index.cjs"
    },
    "./nuxt": {
      "types": "./dist/nuxt/module.d.ts",
      "import": "./dist/nuxt/module.js",
      "require": "./dist/nuxt/module.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run coverage && npm run test:exports && npm run docs:build && npm run pack:dry",
    "coverage": "vitest run test/*.test.ts --coverage",
    "docs:build": "vitepress build docs && node scripts/copy-pages-static.mjs",
    "docs:dev": "vitepress dev docs --host 127.0.0.1",
    "docs:preview": "vitepress preview docs --host 127.0.0.1",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "hooks:install": "node scripts/install-husky.cjs",
    "lint": "eslint . && prettier --check \"**/*.css\"",
    "pack:dry": "npm pack --dry-run",
    "prepare": "npm run build && npm run hooks:install",
    "test": "vitest run test/*.test.ts",
    "test:exports": "npm run build && vitest run smoke/exports.test.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "keywords": [
    "color-mode",
    "dark-mode",
    "nuxt",
    "theme-mode",
    "vue"
  ],
  "browserslist": [
    "baseline widely available with downstream"
  ],
  "dependencies": {
    "@nuxt/kit": "^4.4.2"
  },
  "peerDependencies": {
    "nuxt": "^4.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "nuxt": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nuxt/schema": "^4.4.2",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "nuxt": "^4.4.2",
    "prettier": "^3.8.3",
    "prettier-plugin-css-order": "^2.2.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5",
    "vue": "^3.5.32"
  }
}
